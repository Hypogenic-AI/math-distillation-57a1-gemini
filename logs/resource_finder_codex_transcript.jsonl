{"type":"item.started","item":{"id":"item_29","type":"command_execution","command":"/bin/bash -lc \"source .venv/bin/activate && python - << 'PY'\nfrom pathlib import Path\nfrom pypdf import PdfReader\nimport re, json\nbase=Path('papers/pages')\npatterns=[r'\\\\bDefinition\\\\b',r'\\\\bTheorem\\\\b',r'\\\\bLemma\\\\b',r'\\\\bCorollary\\\\b',r'\\\\bConjecture\\\\b',r'\\\\bProposition\\\\b',r'\\\\bOpen problem\\\\b',r'\\\\bproof\\\\b',r'\\\\bMace4\\\\b',r'\\\\bProver9\\\\b',r'\\\\bSAT\\\\b',r'\\\\bmodel\\\\b']\nrx=re.compile('|'.join(patterns),re.I)\nsets=[\n    sorted(base.glob('2512.07087_equational_theories_project_chunk_*.pdf')),\n    sorted(base.glob('2102.05547_learning_equational_theorem_proving_chunk_*.pdf')),\n]\nout={}\nfor files in sets:\n    if not files: continue\n    key=files[0].name.split('_chunk_')[0]\n    entries=[]\n    for f in files:\n        txt=''\n        r=PdfReader(str(f))\n        for p in r.pages:\n            txt += '\\\\n' + (p.extract_text() or '')\n        lines=[ln.strip() for ln in txt.splitlines() if ln.strip()]\n        hits=[ln for ln in lines if rx.search(ln)]\n        entries.append({\n            'chunk': f.name,\n            'n_lines': len(lines),\n            'hits': hits[:40],\n            'sample': lines[:20],\n        })\n    out[key]=entries\nPath('artifacts').mkdir(exist_ok=True)\nwith open('artifacts/deep_read_notes.json','w') as fh:\n    json.dump(out,fh,indent=2)\nprint('saved artifacts/deep_read_notes.json')\nfor k,v in out.items():\n    print('\\\\n',k,'chunks',len(v))\n    total_hits=sum(len(e['hits']) for e in v)\n    print('total_hits',total_hits)\n    for e in v[:2]:\n        print(' ',e['chunk'],'hits',len(e['hits']))\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
